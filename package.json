{
  "name": "xe-khach-dispatcher",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "dev:full": "concurrently \"npm run dev:backend\" \"npm run wait-for-backend && npm run dev:frontend\"",
    "dev:frontend": "vite",
    "dev:backend": "cd backend && mvn spring-boot:run",
    "wait-for-backend": "wait-on http://localhost:8080/api/health",
    "install:backend": "cd backend && mvn clean install -DskipTests",
    "build:backend": "cd backend && mvn clean package -DskipTests"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.5.0",
    "axios": "^1.6.0",
    "date-fns": "^4.1.0",
    "lucide-react": "^1.8.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hot-toast": "^2.5.1",
    "react-router-dom": "^6.16.0",
    "recharts": "^2.8.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.3",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.20",
    "concurrently": "^8.2.2",
    "postcss": "^8.4.34",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.6.0",
    "vite": "^5.4.21",
    "wait-on": "^8.0.0"
  }
}
